# Required for admin login in production
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_USERNAME=

# Required in production (app errors on startup if missing)
SECRET_KEY=

# Optional — set to 1 for dev login without OAuth (default: 1 locally, 0 in Docker)
DEV_LOGIN=1

# Tailscale auth key for Docker deployment
TS_AUTHKEY=

# Database URL (defaults to local SQLite)
# DATABASE_URL=sqlite:///survivor_fantasy.db

# Data directory for Docker volume mounts
# APPDATA_DIR=.
