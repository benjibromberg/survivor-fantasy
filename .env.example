# GitHub OAuth — create an app at https://github.com/settings/developers
# Required for admin login in production
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_USERNAME=

# Required in production (DEV_LOGIN=0). App errors on startup if missing.
SECRET_KEY=

# Set to 1 for dev login without OAuth, 0 for production
# Default: 1 (locally), 0 (in Docker via docker-compose.yml)
DEV_LOGIN=1

# Tailscale auth key for Docker sidecar deployment
TS_AUTHKEY=

# Database URL (defaults to local SQLite in project root)
# DATABASE_URL=sqlite:///survivor_fantasy.db

# Data directory for Docker volume mounts
# APPDATA_DIR=.

# Flask debug mode (default: 1)
# FLASK_DEBUG=1
